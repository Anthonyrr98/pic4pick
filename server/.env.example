# Server
PORT=3002
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Auth: backend-only. Use strong non-default values in production.
JWT_SECRET=change-this-to-a-random-string-at-least-32-characters-long
ADMIN_USERNAME=pic4pick_admin
ADMIN_PASSWORD=change-this-to-a-strong-password-at-least-12-chars

# Supabase admin API: backend-only. Never expose the service role key to VITE_*.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Aliyun OSS: required for /api/upload/oss.
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_BUCKET=pic4pick
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
# Increase when uploading large images or when OSS is slow to respond.
ALIYUN_OSS_TIMEOUT_MS=300000
UPLOAD_REQUEST_TIMEOUT_MS=600000

# WebDAV: optional.
WEBDAV_URL=https://your-webdav-server.com
WEBDAV_USERNAME=your-username
WEBDAV_PASSWORD=your-password

# Logging
LOG_LEVEL=info
ENABLE_FILE_LOGGING=true
